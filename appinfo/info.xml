<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>valtimo</id>
    <name>Valtimo</name>
    <summary>Valtimo BPM and case management integration for Nextcloud</summary>
    <description><![CDATA[Valtimo Integration for Nextcloud

Integrate Valtimo business process management and case management with your Nextcloud instance.

- Process and case management from Nextcloud
- BPMN workflow integration (Camunda-based)
- Common Ground / ZGW compatible
- Free and open source

This is an ExApp (External Application) - Nextcloud will automatically manage the Valtimo container.

**Note:** Valtimo requires PostgreSQL database and Keycloak for authentication.
    ]]></description>
    <version>0.1.0</version>
    <licence>agpl</licence>
    <author mail="info@conduction.nl" homepage="https://www.conduction.nl/">Conduction</author>
    <category>office</category>
    <category>workflow</category>
    <website>https://github.com/ConductionNL/Valtimo</website>
    <bugs>https://github.com/ConductionNL/Valtimo/issues</bugs>
    <repository>https://github.com/ConductionNL/Valtimo</repository>

    <screenshot>https://raw.githubusercontent.com/ConductionNL/valtimo/main/img/screenshot.png</screenshot>

    <documentation>
        <user>https://docs.valtimo.nl/</user>
        <admin>https://docs.valtimo.nl/</admin>
        <developer>https://docs.valtimo.nl/</developer>
    </documentation>

    <dependencies>
        <nextcloud min-version="30" max-version="33"/>
    </dependencies>

    <external-app>
        <docker-install>
            <registry>localhost:5000</registry>
            <image>valtimo-exapp</image>
            <image-tag>test</image-tag>
        </docker-install>

        <routes>
            <route>
                <url>.*</url>
                <verb>GET,POST,PUT,DELETE,PATCH,OPTIONS</verb>
                <access_level>USER</access_level>
                <headers_to_exclude>[]</headers_to_exclude>
            </route>
        </routes>

        <environment-variables>
            <variable>
                <name>SPRING_DATASOURCE_URL</name>
                <display-name>Database URL</display-name>
                <description>JDBC PostgreSQL connection string (e.g., jdbc:postgresql://host:5432/valtimo)</description>
            </variable>
            <variable>
                <name>SPRING_DATASOURCE_USERNAME</name>
                <display-name>Database Username</display-name>
                <description>Database user</description>
            </variable>
            <variable>
                <name>SPRING_DATASOURCE_PASSWORD</name>
                <display-name>Database Password</display-name>
                <description>Database password</description>
            </variable>
            <variable>
                <name>KEYCLOAK_URL</name>
                <display-name>Keycloak URL</display-name>
                <description>Keycloak server URL for SSO (e.g., http://keycloak:8080)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_REALM</name>
                <display-name>Keycloak Realm</display-name>
                <description>Keycloak realm name (default: commonground)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_CLIENT_ID</name>
                <display-name>Keycloak Client ID</display-name>
                <description>OIDC client ID for this app (default: valtimo)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_CLIENT_SECRET</name>
                <display-name>Keycloak Client Secret</display-name>
                <description>OIDC client secret for this app</description>
            </variable>
        </environment-variables>
    </external-app>
</info>
